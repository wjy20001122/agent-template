{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Feature List Schema",
  "description": "用于约束 feature_list.json，保证 AI Agent 和人类开发者使用同一套功能状态结构。",
  "type": "object",
  "required": ["project", "features", "status_enum", "priority_enum"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "version", "stage", "owner", "updated_at"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "stage": {"type": "string", "enum": ["IDEA", "SPEC", "MVP", "ITERATION", "PRODUCTION"]},
        "owner": {"type": "string", "minLength": 1},
        "updated_at": {"type": "string", "pattern": "^\\{\\{YYYY-MM-DD\\}\\}$|^\\d{4}-\\d{2}-\\d{2}$"}
      },
      "additionalProperties": true
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "priority", "status", "acceptance_criteria", "tasks"],
        "properties": {
          "id": {"type": "string", "pattern": "^F-[0-9]{3,}$"},
          "name": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "priority": {"type": "string", "enum": ["P0", "P1", "P2", "P3"]},
          "status": {"type": "string", "enum": ["TODO", "DOING", "BLOCKED", "DONE", "CANCELLED"]},
          "module": {"type": "string"},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "acceptance_criteria": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "title", "status"],
              "properties": {
                "id": {"type": "string", "pattern": "^T-[0-9]{3,}-[0-9]{2,}$"},
                "title": {"type": "string", "minLength": 1},
                "status": {"type": "string", "enum": ["TODO", "DOING", "BLOCKED", "DONE", "CANCELLED"]}
              },
              "additionalProperties": true
            }
          },
          "notes": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "status_enum": {
      "type": "array",
      "items": {"type": "string", "enum": ["TODO", "DOING", "BLOCKED", "DONE", "CANCELLED"]},
      "minItems": 5
    },
    "priority_enum": {
      "type": "array",
      "items": {"type": "string", "enum": ["P0", "P1", "P2", "P3"]},
      "minItems": 4
    }
  },
  "additionalProperties": true
}
